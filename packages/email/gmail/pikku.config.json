{
  "$schema": "https://raw.githubusercontent.com/pikkujs/pikku/refs/heads/main/packages/cli/cli.schema.json",
  "tsconfig": "./tsconfig.json",
  "srcDirectories": ["src", "types"],
  "outDir": "./.pikku",
  "addon": true,
  "forge": {
    "node": {
      "displayName": "Gmail",
      "description": "Send, receive, and manage emails with Gmail API",
      "categories": ["Messages", "Drafts", "Labels", "Threads"],
      "iconsDir": "./icons",
      "icon": "gmail.svg"
    }
  }
}
