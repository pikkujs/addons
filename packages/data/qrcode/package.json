{
  "name": "@pikku/addon-qrcode",
  "version": "0.1.0",
  "type": "module",
  "imports": {
    "#pikku": "./.pikku/pikku-types.gen.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./.pikku/*": "./dist/.pikku/*",
    "./.pikku/pikku-metadata.gen.json": "./dist/.pikku/pikku-metadata.gen.json",
    "./.pikku/rpc/pikku-rpc-wirings-map.internal.gen.js": {
      "types": "./dist/.pikku/rpc/pikku-rpc-wirings-map.internal.gen.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "pikku all",
    "build": "tsc && cp -r .pikku dist/",
    "pikku": "pikku all",
    "test": "cd test && yarn test"
  },
  "peerDependencies": {
    "@pikku/core": "*",
    "zod": "^4"
  },
  "devDependencies": {
    "@pikku/cli": "^0.12.4",
    "@pikku/core": "^0.12.4",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.7.2",
    "zod": "^4"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5"
  }
}
