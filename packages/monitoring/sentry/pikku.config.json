{
  "$schema": "https://raw.githubusercontent.com/pikkujs/pikku/refs/heads/main/packages/cli/cli.schema.json",
  "tsconfig": "./tsconfig.json",
  "srcDirectories": ["src", "types"],
  "outDir": "./.pikku",
  "addon": true,
  "forge": {
    "node": {
      "displayName": "Sentry",
      "description": "Sentry.io error tracking and monitoring",
      "categories": ["Issues", "Events", "Organizations", "Projects", "Releases", "Teams"],
      "iconsDir": "./icons",
      "icon": "sentry.svg"
    }
  }
}
