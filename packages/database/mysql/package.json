{
  "name": "@pikku/addon-mysql",
  "version": "0.1.2",
  "type": "module",
  "imports": {
    "#pikku": "./dist/.pikku/pikku-types.gen.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./.pikku/*": "./dist/.pikku/*",
    "./.pikku/pikku-metadata.gen.json": "./dist/.pikku/pikku-metadata.gen.json",
    "./.pikku/rpc/pikku-rpc-wirings-map.internal.gen.js": {
      "types": "./dist/.pikku/rpc/pikku-rpc-wirings-map.internal.gen.d.ts"
    }
  },
  "files": [
    "dist",
    ".pikku"
  ],
  "scripts": {
    "prebuild": "pikku all",
    "build": "tsc && cp -r .pikku dist/",
    "pikku": "pikku all",
    "ncu": "npx npm-check-updates",
    "test": "cd test && yarn test"
  },
  "peerDependencies": {
    "@pikku/core": "^0.12.36",
    "zod": "^4"
  },
  "devDependencies": {
    "@pikku/cli": "^0.12.55",
    "@pikku/core": "^0.12.39",
    "typescript": "^5.7.2",
    "zod": "^4"
  },
  "dependencies": {
    "mysql2": "^3.11.5"
  }
}
