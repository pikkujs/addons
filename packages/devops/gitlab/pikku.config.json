{
  "$schema": "https://raw.githubusercontent.com/pikkujs/pikku/refs/heads/main/packages/cli/cli.schema.json",
  "tsconfig": "./tsconfig.json",
  "srcDirectories": [
    "src",
    "types"
  ],
  "outDir": "./.pikku",
  "addon": true,
  "forge": {
    "node": {
      "displayName": "GitLab",
      "description": "DevOps platform",
      "categories": [
        "Projects",
        "Issues"
      ],
      "iconsDir": "./icons",
      "icon": "gitlab.svg"
    }
  }
}
