{
  "$schema": "https://raw.githubusercontent.com/pikkujs/pikku/refs/heads/main/packages/cli/cli.schema.json",
  "tsconfig": "./tsconfig.json",
  "srcDirectories": [
    "src",
    "types"
  ],
  "outDir": "./.pikku",
  "addon": true,
  "forge": {
    "node": {
      "displayName": "GitHub",
      "description": "Code hosting platform",
      "categories": [
        "Repos",
        "Issues"
      ],
      "iconsDir": "./icons",
      "icon": "github.svg"
    }
  }
}
