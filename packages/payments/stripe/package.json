{
  "name": "@pikku/addon-stripe",
  "version": "0.1.2",
  "type": "module",
  "imports": {
    "#pikku": {
      "types": "./.pikku/pikku-types.gen.ts",
      "import": "./dist/.pikku/pikku-types.gen.js"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./.pikku/*": "./.pikku/*",
    "./.pikku/pikku-metadata.gen.json": "./.pikku/pikku-metadata.gen.json",
    "./.pikku/rpc/pikku-rpc-wirings-map.internal.gen.js": {
      "types": "./.pikku/rpc/pikku-rpc-wirings-map.internal.gen.d.ts"
    }
  },
  "publishConfig": {
    "directory": "dist"
  },
  "scripts": {
    "prebuild": "pikku all",
    "build": "tsc && cp -r .pikku dist/ && cp package.json dist/",
    "pikku": "pikku all",
    "ncu": "npx npm-check-updates",
    "test": "cd test && yarn test"
  },
  "dependencies": {
    "stripe": "^17.0.0"
  },
  "peerDependencies": {
    "@pikku/core": "*",
    "zod": "^4"
  },
  "devDependencies": {
    "@pikku/cli": "^0.12.6",
    "@pikku/core": "^0.12.5",
    "typescript": "^5.7.2",
    "zod": "^4"
  }
}
