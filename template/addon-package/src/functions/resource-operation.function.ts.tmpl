import { z } from 'zod'
import { pikkuSessionlessFunc } from '#pikku'

// Input schema
const {{OperationName}}Input = z.object({
  id: z.string().describe('Resource ID'),
  // Add input fields
})

// Output schema
const {{OperationName}}Output = z.object({
  id: z.string(),
  name: z.string(),
  // Add response fields
})

export const {{nodeName}}{{Resource}}{{Operation}} = pikkuSessionlessFunc({
  description: '{{Description}}',
  node: { displayName: '{{Operation Display Name}}', category: '{{Category}}', type: 'action' },
  input: {{OperationName}}Input,
  output: {{OperationName}}Output,
  func: async ({ {{nodeName}} }, data) => {
    // Call the appropriate service method
    return {{nodeName}}.getResource(data.id)
  },
})
