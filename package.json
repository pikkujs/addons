{
  "name": "pikku-addons",
  "private": true,
  "workspaces": [
    "packages/**"
  ],
  "scripts": {
    "pikku": "yarn workspaces foreach -p -A --exclude '@pikku/test-*' run pikku",
    "prebuild": "yarn workspaces foreach -A --exclude '@pikku/test-*' run prebuild",
    "build": "yarn workspaces foreach -A --exclude '@pikku/test-*' run build",
    "tsc": "yarn workspaces foreach -A -p run tsc",
    "test": "yarn workspaces foreach -A run test",
    "ncu": "yarn workspaces foreach -p -A run ncu",
    "clean": "yarn workspaces foreach -A run clean",
    "changeset": "npx changeset",
    "release": "yarn build && npx changeset publish"
  },
  "packageManager": "yarn@4.12.0",
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "node-gyp": "^12.2.0"
  }
}
